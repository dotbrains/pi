{
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.210",
    "@earendil-works/pi-ai": "^0.82.0",
    "@earendil-works/pi-coding-agent": "^0.82.0",
    "@earendil-works/pi-tui": "^0.82.0",
    "@effect/platform-node": "^4.0.0-beta.99",
    "acorn": "^8.17.0",
    "effect": "^4.0.0-beta.99",
    "firecrawl": "^4.30.0",
    "typebox": "^1.3.6"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2"
  },
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "check": "tsc --noEmit",
    "check:extensions": "bash scripts/check-extension-packages.sh",
    "format": "prettier --write \"extensions/**/*.{ts,cjs}\" \"*.json\" \"*.md\" \"docs/**/*.md\" \"skills/*/SKILL.md\"",
    "format:check": "prettier --check \"extensions/**/*.{ts,cjs}\" \"*.json\" \"*.md\" \"docs/**/*.md\" \"skills/*/SKILL.md\"",
    "prepare": "lefthook install",
    "test": "node --test --experimental-strip-types extensions/background-terminals/*.test.ts extensions/firecrawl-search/*.test.ts extensions/git-info/*.test.ts extensions/shared/*.test.ts extensions/subagents/context-usage.test.ts extensions/subagents/manager.test.ts extensions/subagents/result-delivery.test.ts extensions/subagents/takeover.test.ts extensions/workflows/*.test.ts"
  }
}
